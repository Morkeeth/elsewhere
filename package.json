    "react-dom": "19.2.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20.9"
  }
}
