OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
# Optional: a validated JSON result from a successful live witness run. This
# powers GET /api/simulate?agents=1 without spending public-demo API credits.
ELSEWHERE_JUDGE_SIMULATION_JSON=
# Required for production live-witness requests. The app fails closed without
# these durable Upstash REST rate-limit settings and a global daily budget.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Alternatively, Vercel-managed KV supplies compatible KV_REST_API_URL and
# KV_REST_API_TOKEN values automatically.
ELSEWHERE_DEMO_BUDGET=25
